# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Azure Configuration
AZURE_STORAGE_ACCOUNT=your_azure_storage_account
AZURE_STORAGE_KEY=your_azure_storage_key

# SpacetimeDB Configuration
STDB_BIND_ADDRESS=0.0.0.0:3000
STDB_HTTP_BIND_ADDRESS=0.0.0.0:8080
STDB_LOG_LEVEL=info

# Replication Configuration
REPLICATION_MODE=hybrid
REPLICATION_BATCH_SIZE=500
REPLICATION_BATCH_TIMEOUT_MS=100

# Monitoring
PROMETHEUS_RETENTION_DAYS=30
GRAFANA_ADMIN_PASSWORD=admin

# Logging
RUST_LOG=info
ELK_LOG_LEVEL=info

# Security
TLS_ENABLED=true
TLS_CERT_PATH=/etc/ssl/certs/server.crt
TLS_KEY_PATH=/etc/ssl/private/server.key

# NFS Backup (if using)
NFS_SERVER=backup-server.local
NFS_PATH=/exports/spacetimedb
NFS_VERSION=4
